SECRET_KEY=change-this-to-a-random-secret
DATABASE_URL=sqlite:///attendance.db

# App Base URL (Optional - auto-detected if not set)
# For production deployment, set this to your live URL
# Example: APP_BASE_URL=https://your-app.onrender.com
# If not set, the app will auto-detect from request headers
APP_BASE_URL=

# Location Settings
CLASSROOM_RADIUS_METERS=200
# Set to "true" to disable location validation (for testing only)
DISABLE_LOCATION_CHECK=false

# Time Settings
QR_SCAN_ENTRY_WINDOW_MINUTES=10
PRESENCE_TIMEOUT_MINUTES=5
